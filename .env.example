# .env.example — copy to .env and fill in. .env is gitignored.

# ── MLflow tracking (DagsHub-hosted) ─────────────────────────────
# Local dev (docker-compose): http://localhost:5000
# Hosted: https://dagshub.com/<user>/<repo>.mlflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_TRACKING_USERNAME=
MLFLOW_TRACKING_PASSWORD=

# ── DVC / DagsHub storage ────────────────────────────────────────
DAGSHUB_TOKEN=

# ── Slack alerting (optional — no-op if unset) ──────────────────
SLACK_WEBHOOK_URL=

# ── LLM drift analyst ───────────────────────────────────────────
# BYOK (bring your own key): the analyst is on-demand from the frontend and the
# user supplies their own provider key in the UI. The backend reads NO LLM key
# from the environment — nothing to set here.

# ── Serving API (FastAPI on Hugging Face Spaces) ────────────────
# Comma-separated allowed CORS origins (the Vercel frontend URL). * for local dev.
FRONTEND_ORIGINS=*

# ── Hugging Face Space deploy (used by the deploy workflow) ─────
HF_TOKEN=
HF_SPACE_ID=

# ── Prefect ─────────────────────────────────────────────────────
PREFECT_API_URL=http://localhost:4200/api

# ── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
